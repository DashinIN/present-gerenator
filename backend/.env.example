APP_ENV=development
APP_PORT=8080

DATABASE_URL=postgres://fungreet:fungreet@localhost:5433/fungreet?sslmode=disable
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-in-production-min-32-chars!!

STORAGE_MODE=local
STORAGE_LOCAL_DIR=./data/uploads

# API ключ kie.ai (генерация картинок). Оставьте пустым для mock-генератора.
KIE_API_KEY=

# API ключ sunoapi.org (генерация песен). Оставьте пустым для mock-генератора.
SUNO_API_KEY=

# Публичный URL сервера. Если задан — воркер использует webhook-режим вместо polling.
# Обязателен для production. В dev можно оставить пустым.
# BASE_URL=https://yourdomain.com

# При STORAGE_MODE=r2:
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=fungreet
